-- ── Operator Actions table (shadowing data layer) ──
CREATE TABLE IF NOT EXISTS operator_actions (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  operator_name TEXT NOT NULL,
  action_type TEXT NOT NULL,
  resource_type TEXT,
  resource_id TEXT,
  company_id TEXT,
  metadata JSONB DEFAULT '{}',
  created_at TIMESTAMPTZ DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_operator_actions_name ON operator_actions(operator_name);
CREATE INDEX IF NOT EXISTS idx_operator_actions_type ON operator_actions(action_type);
CREATE INDEX IF NOT EXISTS idx_operator_actions_created ON operator_actions(created_at DESC);

ALTER TABLE operator_actions ENABLE ROW LEVEL SECURITY;
